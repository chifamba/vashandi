# Vashandi Full-Stack Environment Template
# Copy this to .env and fill in the values

# 1. Secret Keys
# Required for session management and authentication
BETTER_AUTH_SECRET=32dc59566ad922cbaf5df265fa938f3053db0136296f6fb6d503543ab5f74acb

# 2. OpenBrain Secrets
# Token for direct API access (legacy)
OPENBRAIN_API_KEY=dev_secret_token
# HMAC secret for signed service tokens
OPENBRAIN_SIGNING_SECRET=bc5ed7a59bbd21fad8e12706b37242f3f3a9c8c21ccb22878481daf69aaeb89c

# 3. mTLS Configuration
# Step 1: Run 'docker compose up ca'
# Step 2: Extract the fingerprint from the logs
# Step 3: Paste it here
STEP_CA_PASSWORD=dev_password

# 4. External URL (Optional)
# PAPERCLIP_PUBLIC_URL=http://localhost:3100

# 5. LLM Provider Secrets (Optional)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
STEP_CA_FINGERPRINT=33a3f84de625384e972269a939b0535474987f9fa744ee202d9fd4f2feb5643e
